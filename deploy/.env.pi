# Hermes Pi Environment Configuration
# Copy this to /opt/hermes/app/.env after transfer

# Flask secret key (generated - keep secure)
SECRET_KEY=REPLACE_WITH_GENERATED_KEY

# PIN Authentication
# Generate new hash: python3 -c "from daemons.auth import hash_pin; print(hash_pin('YOUR_PIN'))"
AUTH_ENABLED=true
PIN_HASH=REPLACE_WITH_YOUR_PIN_HASH
